# ============================================
# Urban Pulse AI - .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ---------- Virtual Environment ----------
.venv/
venv/
env/
ENV/

# ---------- YOLO Model Weights ----------
*.pt
*.onnx
*.engine
runs/

# ---------- Video / Media Files ----------
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm

# ---------- Data Files ----------
*.csv
*.json
!package.json
!package-lock.json
*.pkl
*.joblib
*.h5

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ---------- OS Files ----------
Thumbs.db
Desktop.ini
.DS_Store
._*

# ---------- Jupyter ----------
.ipynb_checkpoints/
*.ipynb

# ---------- Logs ----------
*.log

# ---------- Environment Variables ----------
.env
.env.*

# ---------- Node (for frontend) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Misc ----------
*.bak
*.tmp
*.temp
