# ============================================
# Urban Pulse AI v2.0 - .gitignore
# ============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ---------- Virtual Environment ----------
.venv/
venv/
env/
ENV/

# ---------- YOLO Model Weights ----------
*.pt
*.onnx
*.engine
runs/

# ---------- Trained ML Models ----------
models/*.joblib

# ---------- Video / Media Files ----------
data/*.mp4
data/*.avi
data/*.mov
data/*.mkv
data/*.wmv
*.flv
*.webm

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ---------- OS Files ----------
Thumbs.db
Desktop.ini
.DS_Store
._*

# ---------- Jupyter ----------
.ipynb_checkpoints/
*.ipynb

# ---------- Logs ----------
*.log

# ---------- Environment Variables ----------
.env
.env.*

# ---------- Node (for frontend CDN fallback) ----------
node_modules/
npm-debug.log*

# ---------- Misc ----------
*.bak
*.tmp
*.temp
